# Separate v2 credentials. Do not reuse live production service env names.
ENGINE_V2_ENV=prod
ENGINE_V2_LIVE=false
ENGINE_V2_DATA_DIR=C:\Trading\kalshi-btc-engine-v2\data

# Authenticated Kalshi REST/WSS. Leave blank for public-only capture.
ENGINE_V2_KALSHI_KEY_ID=
ENGINE_V2_KALSHI_PRIVATE_KEY_PATH=

# Target series. The capture runner discovers active markets under this series.
ENGINE_V2_KALSHI_SERIES=KXBTC15M
